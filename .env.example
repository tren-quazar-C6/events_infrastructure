# ============================================================================
# events_infrastructure · .env.example
# ----------------------------------------------------------------------------
# Copia este archivo a `.env` y completa los valores.
# NUNCA hagas commit del archivo `.env` (está en .gitignore).
#
# Para generar secretos seguros:
#   openssl rand -hex 32          → JWT_SECRET, N8N_ENCRYPTION_KEY
#   php artisan key:generate      → USERS_APP_KEY (correr dentro del monolito Users)
# ============================================================================

# --- Aplicación general ---
APP_NAME=Tickify
TZ=America/Bogota

# ============================================================================
# Bases de datos
# ============================================================================

# --- MySQL (un solo servidor, 4 bases, 1 usuario por monolito) ---
MYSQL_ROOT_PASSWORD=cambiame_root_seguro
MYSQL_HOST=mysql
MYSQL_PORT=3306

MYSQL_USERS_DB=events_users
MYSQL_USERS_USER=users_app
MYSQL_USERS_PASSWORD=cambiame_users

MYSQL_ADMIN_DB=events_admin
MYSQL_ADMIN_USER=admin_app
MYSQL_ADMIN_PASSWORD=cambiame_admin

MYSQL_TICKETS_DB=events_tickets
MYSQL_TICKETS_USER=tickets_app
MYSQL_TICKETS_PASSWORD=cambiame_tickets

MYSQL_ACCESS_DB=events_access
MYSQL_ACCESS_USER=access_app
MYSQL_ACCESS_PASSWORD=cambiame_access

# --- MongoDB (auditoría y logs) ---
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=cambiame_mongo_root
MONGO_DB=events_logs
MONGO_USER=logs_app
MONGO_PASSWORD=cambiame_mongo

# ============================================================================
# Auth compartida
# ============================================================================

# Users firma los JWT; los demás los validan con el mismo secreto.
JWT_SECRET=cambiame_genera_con_openssl_rand_hex_32
JWT_ISSUER=users.tickify
JWT_TTL=3600   # segundos (1 hora)

# ============================================================================
# Monolitos backend
# ============================================================================

# --- Users (Laravel · PHP) ---
USERS_APP_URL=http://tickify.local
USERS_APP_ENV=local
USERS_APP_DEBUG=true
USERS_APP_KEY=base64:GENERAR_CON_php_artisan_key_generate
USERS_PORT=8000

# OAuth Google (para "Entrar con Google")
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://tickify.local/auth/google/callback

# --- Admin (ASP.NET Core) ---
ADMIN_APP_URL=http://admin.tickify.local
ADMIN_ASPNETCORE_ENVIRONMENT=Development
ADMIN_PORT=8080

# --- Tickets (ASP.NET Core) ---
TICKETS_APP_URL=http://tickets.tickify.local
TICKETS_ASPNETCORE_ENVIRONMENT=Development
TICKETS_PORT=8080

# --- Access (ASP.NET Core) ---
ACCESS_APP_URL=http://access.tickify.local
ACCESS_ASPNETCORE_ENVIRONMENT=Development
ACCESS_PORT=8080

# --- URLs internas (entre contenedores, por nombre de servicio) ---
USERS_INTERNAL_URL=http://users:8000
ADMIN_INTERNAL_URL=http://admin:8080
TICKETS_INTERNAL_URL=http://tickets:8080
ACCESS_INTERNAL_URL=http://access:8080
N8N_INTERNAL_URL=http://n8n:5678

# ============================================================================
# n8n (envío de correos)
# ============================================================================

N8N_PROTOCOL=http
N8N_HOST=localhost
N8N_PORT=5678
N8N_ENCRYPTION_KEY=cambiame_string_aleatorio_largo

# Panel de n8n protegido con basic auth
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=cambiame_n8n_admin

# Webhooks que disparan los backends para enviar correos
N8N_WEBHOOK_WELCOME=http://n8n:5678/webhook/welcome
N8N_WEBHOOK_PASSWORD_RESET=http://n8n:5678/webhook/password-reset
N8N_WEBHOOK_PQRS_RESPONSE=http://n8n:5678/webhook/pqrs-response
N8N_WEBHOOK_FAVORITE_UPDATED=http://n8n:5678/webhook/favorite-event-updated
N8N_WEBHOOK_BOX_OFFICE=http://n8n:5678/webhook/box-office-ticket

# ============================================================================
# SMTP (usado por n8n para enviar correos)
# ============================================================================
# En LOCAL: apunta a Mailpit (captura correos sin enviarlos, los ves en su UI).
# En PROD : reemplaza por SendGrid, AWS SES, Mailgun, etc.

MAIL_FROM_ADDRESS=no-reply@andromeda.andrescortes.dev
MAIL_FROM_NAME=Teatro RobinDev

SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_ENCRYPTION=

# UI web de Mailpit (revisar los correos capturados en local)
MAILPIT_UI_PORT=8025

# ============================================================================
# Pasarela de pagos (Wompi - sandbox)
# ============================================================================
# Crear cuenta en https://comercios.wompi.co y obtener llaves de sandbox.

PAYMENT_PROVIDER=wompi
WOMPI_BASE_URL=https://sandbox.wompi.co/v1
WOMPI_PUBLIC_KEY=pub_test_GENERAR_EN_DASHBOARD
WOMPI_PRIVATE_KEY=prv_test_GENERAR_EN_DASHBOARD
WOMPI_EVENTS_SECRET=GENERAR_EN_DASHBOARD
WOMPI_INTEGRITY_KEY=GENERAR_EN_DASHBOARD

# ============================================================================
# Nginx
# ============================================================================

NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443